@page "/admin/academic-years/create"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@using System.ComponentModel.DataAnnotations
@using CollegeScheduler.DTOs.Academic
@using CollegeScheduler.Services.Interfaces
@inject IAcademicYearService AcademicYearService
@inject NavigationManager Navigation

<h3>Create Academic Year</h3>

<EditForm Model="model" OnValidSubmit="HandleCreate" FormName="CreateAcademicYear">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Label</label>
        <InputText class="form-control" @bind-Value="model.Label" />
    </div>

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <InputDate class="form-control" @bind-Value="model.StartDate" />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <InputDate class="form-control" @bind-Value="model.EndDate" />
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a class="btn btn-secondary ms-2" href="/admin/academic-years">Cancel</a>
</EditForm>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    private AcademicYearCreateDto model = new()
    {
        Label = "",
        StartDate = DateTime.Today,
        EndDate = DateTime.Today.AddYears(1)
    };

    private string? errorMessage;

    private async Task HandleCreate()
    {
        errorMessage = null;

        var success = await AcademicYearService.CreateAsync(model);

        if (success)
        {
            Navigation.NavigateTo("/admin/academic-years");
            return;
        }

        errorMessage = "Failed to create academic year.";
    }
}