@inject NavigationManager Nav

@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms

@page "/admin/buildings/create"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject CollegeScheduler.Services.AdminBuildingsApi Api


@inject CollegeScheduler.Services.AdminCampusState CampusState // Branch 2

<h3>Create Building</h3>

@if (CampusState.SelectedCampusId == 0)
{
    <div class="alert alert-warning">
        No campus selected. Please go back and select a campus.
    </div>
}
else
{
    <div class="alert alert-info">
        Creating building for: <strong>@CampusState.SelectedCampusName</strong>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<EditForm Model="_model" OnValidSubmit="Create">

    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="_model.Name" />
    </div>

    <div class="mb-3">
        <label class="form-label">Code (optional)</label>
        <InputText class="form-control" @bind-Value="_model.Code" />
    </div>

    <button class="btn btn-primary" type="button" @onclick="CreateDirect">
        Create
    </button>

    <button class="btn btn-secondary ms-2" type="button" @onclick="Back" disabled="@_saving">
        Cancel
    </button>


</EditForm>

@code {
    private string? _error;
    private bool _saving;

    private CollegeScheduler.Services.BuildingCreateDto _model = new();

    private async Task Create()
    {
        if (CampusState.SelectedCampusId == 0)
        {
            _error = "Please select a campus before creating a building.";
            return;
        }

        _error = null;
        _saving = true;

        try
        {
            // TEMP: campusId = 1 (same as list)
            await Api.CreateBuildingAsync(CampusState.SelectedCampusId, _model);

            // back to list
            Nav.NavigateTo("/admin/buildings");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CreateDirect()
    {
        if (CampusState.SelectedCampusId == 0)
        {
            _error = "Please select a campus before creating a building.";
            return;
        }

        try
        {
            await Api.CreateBuildingAsync(CampusState.SelectedCampusId, _model);
            Nav.NavigateTo("/admin/buildings");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void Back() => Nav.NavigateTo("/admin/buildings");
}