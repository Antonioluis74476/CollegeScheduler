@inject CollegeScheduler.Services.AdminCampusState CampusState
@inject IJSRuntime JS

@rendermode InteractiveServer
@page "/admin/buildings"

@using CollegeScheduler.DTOs.Facilities
@inject CollegeScheduler.Services.Interfaces.ICampusService CampusService
@inject CollegeScheduler.Services.Interfaces.IBuildingService BuildingService

<h3>Buildings</h3>

<div class="mb-3">
    <label for="campusSelect" class="form-label">Select Campus</label>
    <select id="campusSelect" class="form-select" @bind="selectedCampusValue" @bind:after="LoadBuildingsAsync">
        <option value="">-- Select a campus --</option>
        @foreach (var campus in campuses)
        {
            <option value="@campus.CampusId">@campus.Name - @campus.City</option>
        }
    </select>
</div>

@if (isLoadingCampuses)
{
    <p>Loading campuses...</p>
}
else if (campuses.Count == 0)
{
    <p>No campuses found.</p>
}
else if (string.IsNullOrWhiteSpace(selectedCampusValue))
{
    <p>Please select a campus to view its buildings.</p>
}
else if (isLoadingBuildings)
{
    <p>Loading buildings...</p>
}
else if (buildings.Count == 0)
{
    <p>No buildings found for this campus.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Code</th>
                <th>Faculty</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var building in buildings)
            {
                <tr>
                    <td>@building.BuildingId</td>
                    <td>@building.Name</td>
                    <td>@building.Code</td>
                    <td>@building.Faculty</td>
                    <td>@(building.IsActive ? "Yes" : "No")</td>
                    <td>
                        <a class="btn btn-sm btn-primary me-2"
                           href="/admin/buildings/edit/@building.BuildingId">
                            Edit
                        </a>

                        <button class="btn btn-sm btn-danger"
                                @onclick="() => DeleteBuildingAsync(building.BuildingId, building.Name)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrWhiteSpace(selectedCampusValue))
{
    <a class="btn btn-primary" href="/admin/buildings/create">
        Create Building
    </a>

    <p class="text-muted mt-2">
        Create will use the currently selected campus.
    </p>
}

@code {
    private List<CollegeScheduler.DTOs.Facilities.CampusDto> campuses = new();
    private List<CollegeScheduler.DTOs.Facilities.BuildingDto> buildings = new();

    private bool isLoadingCampuses = true;
    private bool isLoadingBuildings = false;

    private string selectedCampusValue = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var campusResult = await CampusService.GetAllAsync();

            if (campusResult is not null)
            {
                campuses = campusResult.Items
                .GroupBy(c => c.CampusId)
                .Select(g => g.First())
                .OrderBy(c => c.Name)
                .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading campuses: {ex.Message}");
        }
        finally
        {
            isLoadingCampuses = false;
        }
    }



    private async Task LoadBuildingsAsync()
    {
        Console.WriteLine("LoadBuildingsAsync TRIGGERED");

        buildings.Clear();

        if (string.IsNullOrWhiteSpace(selectedCampusValue))
            return;

        if (!int.TryParse(selectedCampusValue, out var campusId))
            return;

        CampusState.SelectedCampusId = campusId;

        CampusState.SelectedCampusName = campuses
            .FirstOrDefault(c => c.CampusId == campusId)?.Name ?? "";
        
        isLoadingBuildings = true;

        try
        {
            var buildingResult = await BuildingService.GetByCampusAsync(campusId);

            if (buildingResult is not null)
            {
                buildings = buildingResult.Items
                    .Where(b => b.IsActive)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading buildings: {ex.Message}");
        }
        finally
        {
            isLoadingBuildings = false;
        }
    }

    private async Task DeleteBuildingAsync(int buildingId, string buildingName)
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Delete building '{buildingName}'?"
        );

        if (!confirmed)
            return;

        try
        {
            var success = await BuildingService.DeleteAsync(buildingId);

            if (success)
            {
                await LoadBuildingsAsync();
            }
            else
            {
                Console.WriteLine("Delete failed.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting building: {ex.Message}");
        }
    }


}

